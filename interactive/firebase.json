{
  "hosting": {
    "site": "de-lab-interview-gym",
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "README.md",
      "vercel.json"
    ],
    "headers": [
      {
        "source": "**/*.@(js|css|json)",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache" }
        ]
      }
    ]
  }
}
