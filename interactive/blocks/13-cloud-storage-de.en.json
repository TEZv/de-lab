    {
      "id": "A3",
      "type": "whats_wrong",
      "tag": "☁️ · 3/6 · IAM",
      "title": "What's wrong with this policy?",
      "instruction": "Classic junior DE trap on AWS.",
      "mission": {
        "emoji": "🔐",
        "title": "Security review",
        "brief": "ETL role should read bronze and write silver. No public access."
      },
      "buggyCode": "{\n  \"Version\": \"2012-10-17\",\n  \"Statement\": [{\n    \"Effect\": \"Allow\",\n    \"Principal\": \"*\",\n    \"Action\": \"s3:*\",\n    \"Resource\": \"arn:aws:s3:::acme-datalake/*\"\n  }]\n}",
      "prompt": "Main risk in this bucket policy?",
      "options": [
        "Principal * + s3:* on whole bucket = public full access; need IAM role for ETL and minimal Action/Resource",
        "Version must be 2024",
        "Resource without /* is always forbidden",
        "s3:* must be replaced with s3:GetObject only for Glacier"
      ],
      "correctIndex": 0,
      "explainOk": "Least privilege: service role, specific prefixes (bronze/* read, silver/* write), no Principal *.",
      "explanation": "On interview: «enable public access block + role-based access»."
    },
    {
      "id": "A4",
      "type": "multi_choice",
      "tag": "☁️ · 4/6",
      "title": "Lifecycle · cost",
      "instruction": "Data older than 90 days is rarely read but must stay for audit.",
      "mission": {
        "emoji": "💰",
        "title": "FinOps",
        "brief": "1 TB logs in Standard. Read once per quarter. What do you do?"
      },
      "question": "Smartest lifecycle for rarely read raw logs?",
      "options": [
        "Rule: after 90 days → Glacier / Archive tier; hot only last month",
        "Keep everything in Standard — simpler",
        "Delete everything older than 7 days without compliance sign-off",
        "Copy to RDS Postgres for cheaper storage"
      ],
      "correctIndex": 0,
      "explanation": "Lifecycle / tiering lowers cost; compliance → no delete without policy."
    },
