      "title": "MATCH · cloud ↔ term",
      "instruction": "One concept — three vendors. Know the equivalents.",
      "pairs": [
        {
          "left": "S3 bucket",
          "right": "Azure Blob container ≈ GCS bucket"
        },
        {
          "left": "S3 object key",
          "right": "Blob name ≈ GCS object path"
        },
        {
          "left": "IAM role + policy",
          "right": "Azure RBAC ≈ GCS IAM"
        },
        {
          "left": "s3://bucket/prefix/",
          "right": "https://acct.blob.core.windows.net/c/ ≈ gs://bucket/"
        },
        {
          "left": "Lifecycle → Glacier",
          "right": "Cool/Archive tier ≈ Nearline/Coldline"
        }
      ]
    },
