    {
      "id": "D5",
      "type": "whats_wrong",
      "tag": "🌊 · 5/7",
      "title": "What's wrong with consumer?",
      "instruction": "Stream crashes — consumer reads topic from start without dedup.",
      "mission": {
        "emoji": "🔁",
        "title": "At-least-once delivery",
        "brief": "Duplicate events land in mart."
      },
      "buggyCode": "for event in kafka_consumer:\n    row = parse(event)\n    insert_into_dwh(row)  # no key, no dedup\n    # offset commit after each batch — OK\n    # but rerun / retry → same event twice",
      "prompt": "Main risk for mart?",
      "options": [
        "Insert without idempotency on event_id → dupes with at-least-once",
        "Kafka forbids offset commit",
        "parse() always returns NULL",
        "Stream cannot write to DWH"
      ],
      "correctIndex": 0,
      "explainOk": "Like incremental: natural key + MERGE or dedup window; exactly-once is harder.",
      "explanation": "Stream = same idempotency as Phase C."
    },
