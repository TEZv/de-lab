      "title": "What's wrong with this DAG?",
      "instruction": "Junior added DAG to prod — thousands of backfill runs appear.",
      "mission": {
        "emoji": "🔥",
        "title": "Code review",
        "brief": "start_date far in the past + catchup enabled.",
        "ask": "Main mistake?"
      },
      "buggyCode": "from airflow import DAG\nfrom datetime import datetime\n\nwith DAG(\n    dag_id='daily_mart',\n    start_date=datetime(2020, 1, 1),\n    schedule_interval='@daily',\n    catchup=True,\n) as dag:\n    extract >> transform >> load_mart",
      "prompt": "Why is this dangerous in prod?",
      "options": [
        "catchup=True + old start_date → Airflow creates a DAG run for every missed day since 2020",
        "schedule_interval @daily is forbidden in Airflow 2",
        "extract >> transform syntax is wrong",
        "dag_id must be a UUID"
      ],
      "correctIndex": 0,
      "explainOk": "New DAG: catchup=False or start_date ≈ today; backfill only deliberately.",
      "explanation": "On interview: «check catchup and start_date before merge»."
    },
